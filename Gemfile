source "https://rubygems.org"

# Mirrors the GitHub Pages build environment for local previews.
gem "github-pages", group: :jekyll_plugins
gem "webrick", "~> 1.8"

# Pin native deps to versions compatible with the local Ruby 2.6 toolchain.
# (GitHub Pages CI uses its own Ruby, so this only affects local previews.)
gem "ffi", "< 1.17"
